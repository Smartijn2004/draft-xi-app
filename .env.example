# Where feedback submissions get delivered.
# Slack: api.slack.com/apps → Create New App → Incoming Webhooks → Add to
# Workspace → copy the URL here. Discord webhooks also work.
# If unset, feedback is logged to the server console instead.
FEEDBACK_WEBHOOK_URL=

# Daily-challenge leaderboard storage (Turso / libSQL).
# Create a free DB at turso.tech, then:
#   turso db create draft-xi
#   turso db show draft-xi --url        → TURSO_DATABASE_URL (libsql://…)
#   turso db tokens create draft-xi     → TURSO_AUTH_TOKEN
# If unset, the leaderboard simply hides itself and the rest of the game works.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
